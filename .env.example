# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Supabase (public, safe for client bundles)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini API (for AI music suggestions)
GEMINI_API_KEY=your-gemini-api-key

# Resend (transactional email)
RESEND_API_KEY=re_your-resend-api-key

# Sender identity — MUST be a verified domain in Resend for production
# (the resend.dev sandbox address only delivers to the account owner).
EMAIL_FROM=Precentor <noreply@precentor.app>

# Cron job authentication
CRON_SECRET=your-cron-secret

# Public-facing URL
NEXT_PUBLIC_APP_URL=https://precentor.app

# LLM provider (optional, defaults to gemini)
LLM_PROVIDER=gemini

# Role-slots feature flag — set to "true" to enable the new role/preset model
# during migration cutover. Default false.
USE_ROLE_SLOTS_MODEL=false

# Comma-separated list of super-admin emails permitted to access /api/admin/migration-log.
SUPER_ADMIN_EMAILS=
